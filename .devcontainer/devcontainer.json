{
    "name": "Pebble Dev",
    "build": {
        // Context is the workspace root so the Dockerfile can reference workspace files if needed
        "dockerfile": "Dockerfile",
        "context": ".."
    },

    // Mount the workspace and the host-side ~/.agents directory
    "workspaceFolder": "/workspace",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
    "mounts": [
        // ~/.agents/ contains skills, prompts and other agent config that persists on your Mac.
        // Back this directory up to a private GitHub repo independently of this project.
        "source=${localEnv:HOME}/.agents,target=/agents,type=bind,consistency=cached"
    ],

    // Expose agent config paths as env vars so agents can discover them without hard-coding paths
    "remoteEnv": {
        "AGENTS_DIR": "/agents",
        "SKILLS_DIR": "/agents/skills",
        "DISPLAY": "host.docker.internal:0"
    },

    "postCreateCommand": "cd /workspace/blue_pixel && pebble package install @rebble/clay",

    "customizations": {
        "vscode": {
            "extensions": [
                // C/C++ intellisense for watchface source
                "ms-vscode.cpptools",
                // Agent tooling
                "GitHub.copilot",
                "GitHub.copilot-chat"
            ]
        }
    },

    "remoteUser": "vscode"
}
